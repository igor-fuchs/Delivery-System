@baseUrl = http://localhost:8080

### ── Auth ──────────────────────────────────────────────────────

@token = {{login.response.body.token}}
@userId = {{login.response.body.id}}

### Register a new user
POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
  "email": "igorfuchs111@gmail.com",
  "password": "Password123!",
  "captchaToken": "captcha-token"
}

### Login
# @name login
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "igorfuchs111@gmail.com",
  "password": "Password123!",
  "captchaToken": "captcha-token"
}

### Login with Google
# @name googleLogin
POST {{baseUrl}}/api/auth/google
Content-Type: application/json

{
  "token": "eyJhbGciOiJSUzI1NiJ9.eyJzdWIiOiIxMjM0NTY3ODkwIn0.invalid-signature"
}

### Forgot password (sends reset email)
# Step 1 — request the reset link. Check your email for the link.
POST {{baseUrl}}/api/auth/forgot-password
Content-Type: application/json

{
  "email": "igorfuchs111@gmail.com",
  "captchaToken": "captcha-token",
  "callbackUrl": "http://localhost:3000/reset-password"
}

### Reset password
# Step 2 — copy userId and token from the link received in the email (?userId=...&token=...)
# and paste them below. The token must be URL-decoded before sending.
POST {{baseUrl}}/api/auth/reset-password
Content-Type: application/json

{
  "userId": "{{userId}}",
  "token": "CfDJ8KUk7I8uqb5Ojn05bdeQ2wR2UOF%2FhOGo%2Fp421I61DX%2FqUPKzh%2B3k3V2VrpjIMNIoGVgDuSvmm6IPcZfPneCH8MjpjBbW%2B%2FfC%2Fde1Gdvv6KAM%2BZ7VAwwbwJmj4z3cXzkJKR2nnyzBXsSsqasdcnl7QL8ksUqTrLwhU90Y11U7pNn088pi6HE73PAIdPFOoNAwu9xmpT3RJP3ufA7DW7wEJZcGuc2w1P7Uw28piOSIpCzW",
  "newPassword": "NewPassword123!",
  "captchaToken": "captcha-token"
}

### ── Products ──────────────────────────────────────────────────

@productId = {{createProduct.response.body.id}}

### Get all products (requires authentication)
GET {{baseUrl}}/api/products
Authorization: Bearer {{token}}

### Get product by ID
GET {{baseUrl}}/api/products/{{productId}}
Authorization: Bearer {{token}}

### Create product (admin only)
# @name createProduct
POST {{baseUrl}}/api/products
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Burger Deluxe",
  "description": "Delicious burger with bacon, lettuce, tomato and special sauce",
  "stock": true,
  "price": 15.99
}

### Update product (admin only)
PUT {{baseUrl}}/api/products/{{productId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Burger Premium",
  "description": "Updated description for premium burger",
  "stock": true,
  "price": 18.99
}

### Delete product (admin only)
DELETE {{baseUrl}}/api/products/{{productId}}
Authorization: Bearer {{token}}

### ── Orders ────────────────────────────────────────────────────

@orderId = {{createOrder.response.body.id}}

### Get all orders (users see only their own, admins see all)
GET {{baseUrl}}/api/orders
Authorization: Bearer {{token}}

### Get order by ID
GET {{baseUrl}}/api/orders/{{orderId}}
Authorization: Bearer {{token}}

### Create order (authenticated users)
# @name createOrder
POST {{baseUrl}}/api/orders
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "description": "Delivery for Friday evening",
  "items": [
    {
      "productId": "{{productId}}",
      "quantity": 2
    },
    {
      "productId": "{{productId}}",
      "quantity": 1
    }
  ]
}

### Update order status (admin only)
PUT {{baseUrl}}/api/orders/{{orderId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "status": "Shipped"
}

### Delete order (admin only)
DELETE {{baseUrl}}/api/orders/{{orderId}}
Authorization: Bearer {{token}}
