{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Jwt": {
    "Issuer": "DeliverySystem",
    "Audience": "DeliverySystem",
    "ExpirationMinutes": 60
  },
  "Recaptcha": {
    "MinimumScore": 0.5
  },
  "RateLimit": {
    "AuthPermitLimit": 5,
    "AuthWindowMinutes": 1,
    "GlobalPermitLimit": 30,
    "GlobalWindowMinutes": 1
  }
}