{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Jwt": {
    "Issuer": "DeliverySystem",
    "Audience": "DeliverySystem",
    "ExpirationMinutes": 60
  },
  "Recaptcha": {
    "MinimumScore": 0.5
  },
  "RateLimit": {
    "AuthPermitLimit": 20,
    "AuthWindowMinutes": 10,
    "GlobalPermitLimit": 100,
    "GlobalWindowMinutes": 1,
    "ProductsPermitLimit": 40,
    "ProductsWindowMinutes": 1,
    "OrdersPermitLimit": 10,
    "OrdersWindowMinutes": 1
  },
  "Redis": {
    "InstanceName": "DeliverySystem:",
    "ProductCacheTtlMinutes": 10
  },
  "Cors": {
    "AuthAllowedOrigins": [
      "http://localhost:5173"
    ],
    "AuthAllowedMethods": [
      "POST"
    ]
  }
}